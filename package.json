{
  "name": "battle-dev",
  "version": "2.8.2",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node scripts/vitest.mjs",
    "test:coverage": "node scripts/vitest.mjs --coverage",
    "test:coverage:strict": "node scripts/vitest.mjs --coverage --config vitest.strict.config.js",
    "build": "npm run test:coverage:strict",
    "test:raw": "vitest",
    "rebalance": "node scripts/rebalance.mjs",
    "rebalance:suggest": "node scripts/rebalance.mjs --suggest"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "vitest": "^4.1.0"
  }
}
